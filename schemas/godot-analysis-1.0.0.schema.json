    "plugins": {"type": "array", "items": {"type": "object"}}, "exports": {"type": "array", "items": {"type": "object"}},
    "tests": {"type": "object"}, "native_extensions": {"type": "array", "items": {"type": "string"}}, "assets": {"type": "object"},
    "gameplay_systems": {"type": "array", "items": {"type": "object"}}, "signals": {"type": "array", "items": {"type": "object"}},
