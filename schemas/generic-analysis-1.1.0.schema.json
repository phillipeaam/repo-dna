{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://github.com/phillipeaam/repo-dna/schemas/generic-analysis-1.1.0.schema.json","title":"RepoDNA generic analysis","type":"object","additionalProperties":false,
  "required":["$schema","schema_version","collector","file_count","language_count","configuration_file_count","documentation_file_count","test_file_count","ci_cd_file_count","docker_file_count","languages","extensions","largest_files","top_directories","configuration_files","documentation_files","test_files","ci_cd_files","docker_files","dependencies","technology_inventory","possible_modules","git","analysis"],
  "properties":{
