    "extensions":{"type":"array","items":{"type":"object"}},"largest_files":{"type":"array","items":{"type":"object"}},"top_directories":{"type":"array","items":{"type":"object"}},
    "configuration_files":{"$ref":"#/$defs/strings"},"documentation_files":{"$ref":"#/$defs/strings"},"test_files":{"$ref":"#/$defs/strings"},"ci_cd_files":{"$ref":"#/$defs/strings"},"docker_files":{"$ref":"#/$defs/strings"},
    "dependencies":{"type":"object","required":["manifests","total"],"properties":{"manifests":{"type":"array","items":{"type":"object"}},"total":{"$ref":"#/$defs/count"}}},
    "technology_inventory":{"type":"object","required":["languages","runtimes","package_managers","declared_dependencies","frameworks","build_tools","ci_cd","test_tools","lint_tools","configuration_files","documentation_files","containerization","technologies","technology_count"]},
    "possible_modules":{"type":"array","items":{"type":"object"}},
    "git":{"type":"object","required":["scope","contributors_count","contributors","system_evolution","branches_count","branches","tags_count","tags","recent_tags","history_by_month","history_by_year","churn","hotspots","hotspot_model","technical_impact"],"properties":{"tags":{"type":"array","items":{"type":"string"}},"recent_tags":{"type":"array","items":{"type":"string"},"maxItems":30},"hotspot_model":{"type":"object","required":["model","version","formula","components","interpretation"],"properties":{"model":{"const":"repodna-composite-hotspot"},"version":{"type":"string"},"formula":{"type":"string"},"components":{"type":"object"},"interpretation":{"type":"string"}}},"hotspots":{"type":"array","items":{"type":"object","required":["path","model","version","commits","churn","current_lines","authors","days_since_last_change","score"]}}}},
    "analysis":{"type":"object","required":["architecture","code","systems","author_system_ownership","bus_factor_by_system","onboarding","unity","android","flutter","godot","unreal","dependency_inventory","delivery","forge_activity","personal_achievement_candidates","frameworks","graphs","quality","health","narrative_facts"]}
